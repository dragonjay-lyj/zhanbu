# ======================================
# ZhanBu - Environment Variables Example
# ======================================

# ----------------------
# Supabase (Required)
# ----------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ----------------------
# Clerk (Required)
# ----------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Clerk webhook signing secret for /api/webhooks/clerk
CLERK_WEBHOOK_SECRET=whsec_xxx

# ----------------------
# App (Required)
# ----------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ZhanBu 占卜

# Optional SEO site URL (fallback if unset)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ----------------------
# AI (Optional)
# If you use system settings in /admin/settings, these can be left empty.
# ----------------------
AI_API_KEY=
AI_API_BASE_URL=https://api.deepseek.com/v1
AI_MODEL=deepseek-chat

# Compatibility aliases used by some routes
AI_BASE_URL=https://api.deepseek.com

# ----------------------
# Linux DO Credit (Optional but recommended for production)
# ----------------------
LINUX_DO_CREDIT_PID=
LINUX_DO_CREDIT_KEY=
LINUX_DO_CREDIT_GATEWAY=https://credit.linux.do/epay
LINUX_DO_CREDIT_RATE=10
LINUX_DO_CREDIT_NOTIFY_URL=
LINUX_DO_CREDIT_RETURN_URL=

# ----------------------
# Legacy payment webhook secret (optional)
# ----------------------
PAYMENT_WEBHOOK_SECRET=
